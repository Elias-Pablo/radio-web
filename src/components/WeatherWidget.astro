---
import Image from "astro/components/Image.astro";
import Badge from "./ui/Badge.astro";
import Card from "./ui/Card.astro";

const comunas = [
  { name: "Rengo", id: 3873441 },
  { name: "Requínoa", id: 3873414 },
  { name: "Quinta de Tilcoco", id: 3873775 },
  { name: "Malloa", id: 3880827 },
  { name: "Coinco", id: 3873441 },
  { name: "Coltauco", id: 3893999 },
  { name: "Doñihue", id: 3892272 },
  { name: "Graneros", id: 3888749 },
  { name: "Pichilemu", id: 3875070 },
  { name: "Rancagua", id: 3873775 },
];

const weatherApiKey = import.meta.env.OPENWEATHER_API_KEY;

async function fetchWeatherData(comunaId) {
  if (!weatherApiKey) {
    return null;
  }

  try {
    const response = await fetch(
      `https://api.openweathermap.org/data/2.5/weather?id=${comunaId}&appid=${weatherApiKey}&units=metric&lang=es`
    );

    if (!response.ok) {
      throw new Error("Error fetching weather data");
    }

    const data = await response.json();
    return data;
  } catch (error) {
    console.error("Error fetching weather data for ID:", comunaId, error);
    return null;
  }
}

const weatherData = await Promise.all(
  comunas.map((comuna) => fetchWeatherData(comuna.id))
);
function getTemp(temp = 0) {
  if (temp <= 15) {
    return "text-blue-500"; // Cold: Blue
  } else if (temp > 15 && temp <= 23) {
    return "text-yellow-500"; // Warm: Yellow
  } else {
    return "text-orange-600"; // Hot: Orange
  }
}
---

<section class="section-shell bg-background">
  <div class="container-page">
    <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <Badge variant="secondary">Servicio regional</Badge>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl">
          Clima en la zona
        </h2>
        <p class="mt-2 max-w-2xl text-sm text-muted-foreground sm:text-base">
          Temperatura y condiciones actuales para comunas de O'Higgins.
        </p>
      </div>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="hidden text-sky-300 sm:block"
        aria-hidden="true"
        ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
          d="M4 13.5a4 4 0 1 0 4 0v-8.5a2 2 0 1 0 -4 0v8.5"></path><path
          d="M4 9h4"></path><path
          d="M13 16a4 4 0 1 0 0 -8a4.07 4.07 0 0 0 -1 .124"></path><path
          d="M13 3v1"></path><path d="M21 12h1"></path><path d="M13 20v1"
        ></path><path d="M19.4 5.6l-.7 .7"></path><path d="M18.7 17.7l.7 .7"
        ></path></svg
      >
    </div>

  {
    weatherData.length > 0 ? (
      <div class="grid grid-cols-2 gap-3 md:grid-cols-5">
        {weatherData.map((data, index) => (
          <Card class="flex min-h-48 flex-col items-center justify-center border-sky-500/20 bg-sky-500/10 p-4 text-center transition hover:-translate-y-1 hover:bg-sky-500/15">
            <h3 class="font-bold text-white lg:text-lg">{comunas[index].name}</h3>
            {data ? (
              <>
                <Image
                  src={`https://openweathermap.org/img/wn/${data.weather[0].icon}@4x.png`}
                  alt={data.weather[0].description}
                  width={100}
                  height={100}
                  class="my-1 drop-shadow-lg"
                />
                <p class="flex flex-col items-center justify-center text-xs text-muted-foreground md:text-sm">
                  Temperatura
                  <span
                    class={`text-2xl font-black md:text-3xl ${getTemp(data.main?.temp)}`}
                  >
                    {Math.round(data.main?.temp ?? 0)}°C
                  </span>
                </p>
                <p class="mt-2 text-xs capitalize text-muted-foreground md:text-sm">
                  <span class="font-semibold text-white">
                    {data.weather?.[0]?.description || "No disponible"}
                  </span>
                </p>
              </>
            ) : (
              <p class="mt-4 text-sm text-muted-foreground">
                Datos no disponibles
              </p>
            )}
          </Card>
        ))}
      </div>
    ) : (
      <Card class="p-6 text-center text-muted-foreground">
        Cargando datos del clima...
      </Card>
    )
  }
  </div>
</section>
