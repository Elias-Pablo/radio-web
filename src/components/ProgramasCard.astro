---
import Image from "astro/components/Image.astro";
import Badge from "./ui/Badge.astro";
import Card from "./ui/Card.astro";

const programas = [
  {
    title: "Manita Deportes",
    autor: "Mauricio Pérez y Patricio Ramírez",
    time: "Lunes a Viernes de 20:00 a 21:00 hrs.",
    description:
      "Sigue todas las noticias deportivas de la región y el mundo en Manita Deportes.",
    image: "/Logo-Manita.png",
  },
  {
    title: "El Vitrola",
    autor: "El Vitrola de Chile",
    time: "Lunes a Viernes de 21:00 a 00:00 hrs.",
    description:
      "El mejor programa de música tropical-ranchera de la sexta región. Con décadas de trayectoria.",
    image: "/logo-vitro.png",
  },
  {
    title: "Noticias Radios Regionales",
    autor: "Radios Regionales",
    time: "Lunes a Viernes a las 08:00, 15:15 y 21:30 hrs.",
    description:
      "Las noticias más importantes de la región y el país en Radios Regionales.",
    image: "/radiosregionales.jpg",
  },
  {
    title: "Dos en el Café",
    autor: "Patricio Rojas Caro",
    time: "Lunes a Viernes de 19:00 a 20:00 hrs.",
    description:
      "Dos en el Café, un programa de conversación para acompañar la hora del café.",
    image: "/logo2cafe.png",
  },
  {
    title: "Gente Femenina",
    autor: "Lorena Contreras Ruz",
    time: "Viernes de 18:00 a 19:00 hrs.",
    description:
      "Un programa dedicado a la mujer, con temas de interés, actualidad y entrevistas.",
    image: "/Gentefeme.png",
  },
  {
    title: "El Vacilón Tropical",
    autor: "Peter Duarte",
    time: "Lunes a Viernes de 13:00 a 15:00 hrs.(Miércoles de 13:00 a 14:00 hrs.)",
    description:
      "El mejor programa de música tropical para acompañar tus tardes con la conducción del entretenido, historíco y gran Peter Duarte.",
    image: "/Vacilon-logo.png",
  },

  {
    title: "Programación de la Ilustre Municipalidad de Requínoa",
    autor: "Ilustre Municipalidad de Requínoa",
    time: "Lunes a Viernes de 10:00 a 13:00 hrs. y de 16:00 a 18:00 hrs. (Viernes solo de 10:00 a 13:00 hrs.)",
    description:
      "Programación de la Ilustre Municipalidad de Requínoa, con la mejor música, noticias y entretención.",
    image: "/muni-requinoa.jpeg",
  },
  {
    title: "Entre Nos",
    autor: "Patricio Rojas Caro",
    time: "Sábados de 10:00 a 12:00 hrs.",
    description:
      "Entre Nos, un programa de conversación para acompañar tus mañanas de sábado.",
    image: "/entre-nos-logo.png",
  },
];
---

<section class="section-shell relative overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-primary/20 via-accent/10 to-sky-500/20"></div>
  <div class="container-page">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      <Badge variant="accent">Parrilla radial</Badge>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-white sm:text-5xl">
        Nuestros Programas
      </h1>
      <p class="mt-4 text-sm text-muted-foreground sm:text-base">
        Voces locales, conversación, deportes, música y actualidad para acompañarte todos los días.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      programas.map((programa) => (
        <Card class="group flex h-full flex-col overflow-hidden border-white/10 bg-card/85 p-5 transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/10">
          <div class="flex h-36 items-center justify-center rounded-xl bg-white p-4">
            <Image
              src={programa.image}
              alt={programa.title}
              width={250}
              height={120}
              class="max-h-28 w-auto object-contain drop-shadow-md transition duration-300 group-hover:scale-105"
              loading="eager"
            />
          </div>
          <div class="mt-5 flex flex-1 flex-col text-center">
            <h2 class="text-xl font-black text-white">
              {programa.title}
            </h2>
            <p class="mt-2 text-sm text-muted-foreground">
              <span class="font-bold text-primary">Conduce: </span>
              {programa.autor}
            </p>
            <p class="mt-3 rounded-full border border-white/10 bg-white/5 px-3 py-2 text-xs font-semibold text-muted-foreground">
              {programa.time}
            </p>
            <p class="mt-4 flex-1 text-sm leading-relaxed text-muted-foreground">
              {programa.description}
            </p>
          </div>
        </Card>
      ))
    }
    </div>
  </div>
</section>
