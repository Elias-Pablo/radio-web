---
import Image from "astro/components/Image.astro";
import Badge from "./ui/Badge.astro";
import Button from "./ui/Button.astro";
import Card from "./ui/Card.astro";

type Article = {
  title?: string;
  description?: string;
  url?: string;
  urlToImage?: string;
  source?: { name?: string };
};

const newsApiKey = import.meta.env.NEWS_API_KEY;
const NEWS_API_URL = newsApiKey
  ? `https://newsapi.org/v2/everything?q="Chile"&sortBy=publishedAt&pageSize=20&language=es&apiKey=${newsApiKey}`
  : "";

const fetchNews = async () => {
  if (!NEWS_API_URL) {
    return [] as Article[];
  }

  try {
    const response = await fetch(NEWS_API_URL);

    if (!response.ok) {
      throw new Error("Error fetching news");
    }

    const data = await response.json();
    return Array.isArray(data.articles) ? (data.articles as Article[]) : [];
  } catch (error) {
    console.error("Error fetching news:", error);
    return [] as Article[];
  }
};

const articles = (await fetchNews())
  .filter((article) => article.title && article.title !== "[Removed]" && article.url)
  .slice(0, 6);
---

<section class="section-shell border-y border-border/60 bg-muted/20">
  <div class="container-page">
    <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <Badge variant="accent">Actualidad</Badge>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl">
          Noticias destacadas
        </h2>
        <p class="mt-2 max-w-2xl text-sm text-muted-foreground sm:text-base">
          Una selección de titulares recientes para mantener informada a la comunidad.
        </p>
      </div>
      <svg
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="hidden text-primary sm:block"
        aria-hidden="true"
        ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
          d="M16 6h3a1 1 0 0 1 1 1v11a2 2 0 0 1 -4 0v-13a1 1 0 0 0 -1 -1h-10a1 1 0 0 0 -1 1v12a3 3 0 0 0 3 3h11"
        ></path><path d="M8 8l4 0"></path><path d="M8 12l4 0"></path><path
          d="M8 16l4 0"></path></svg
      >
    </div>

    {
      articles.length > 0 ? (
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {articles.map((article) => (
            <Card class="group flex h-full flex-col overflow-hidden border-white/10 bg-card/85 transition hover:-translate-y-1 hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/10 sm:flex-row">
            {article.urlToImage && (
              <div class="h-48 overflow-hidden bg-muted sm:h-auto sm:w-2/5">
                <Image
                  src={article.urlToImage}
                  alt={article.title ?? "Noticia"}
                  width={320}
                  height={220}
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                />
              </div>
            )}
            <div class="flex flex-1 flex-col p-5">
              {article.source?.name && (
                <span class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-primary">
                  {article.source.name}
                </span>
              )}
              <h3 class="text-lg font-black leading-tight text-white lg:text-xl">
                {article.title}
              </h3>
              <p class="mt-3 line-clamp-3 text-sm text-muted-foreground">
                {article.description ?? "Revisa el detalle completo en la fuente original."}
              </p>
              <Button
                href={article.url ?? "#"}
                target="_blank"
                variant="outline"
                size="sm"
                class="mt-5 w-fit"
              >
                Leer más
              </Button>
            </div>
          </Card>
          ))}
        </div>
      ) : (
        <Card class="p-8 text-center text-muted-foreground">
          No hay noticias disponibles en este momento. Verifica la configuración de NEWS_API_KEY.
        </Card>
      )
    }
  </div>
</section>
