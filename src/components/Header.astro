---
import Image from "astro/components/Image.astro";
import Button from "./ui/Button.astro";

const navItems = [
  { href: "/programas", label: "Programas" },
  { href: "/sobrenosotros", label: "Sobre Nosotros" },
  { href: "/contacto", label: "Contacto" },
];
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-background/85 backdrop-blur-xl"
  data-astro-transition-persist="site-header"
>
  <div class="container-page flex h-20 items-center justify-between gap-4">
    <a href="/" class="flex min-w-0 items-center gap-3" aria-label="Ir al inicio">
      <span class="rounded-2xl border border-white/10 bg-white/5 p-2 shadow-lg shadow-black/30">
        <Image
          src="/logo-blanco.png"
          alt="Gente Comunicaciones"
          width={64}
          height={64}
          loading="eager"
          class="h-12 w-12 object-contain"
        />
      </span>
      <span class="hidden min-w-0 flex-col sm:flex">
        <span class="truncate text-sm font-black uppercase tracking-[0.22em] text-white">
          Gente Comunicaciones
        </span>
        <span class="text-xs font-medium text-muted-foreground">
          94.5 FM Rengo
        </span>
      </span>
    </a>

    <nav class="hidden items-center rounded-full border border-white/10 bg-white/5 p-1 text-sm font-semibold text-muted-foreground lg:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="rounded-full px-4 py-2 transition hover:bg-white/10 hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <div class="relative">
        <button
          id="liveButton"
          type="button"
          data-state="idle"
          data-stream-url="/api/radio"
          class="group relative inline-flex h-11 min-w-32 items-center justify-center gap-2 overflow-hidden rounded-full border border-red-300/40 bg-gradient-to-r from-red-600 via-red-500 to-amber-500 px-3 text-white shadow-lg shadow-red-950/40 transition hover:-translate-y-0.5 hover:shadow-red-900/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-300 focus-visible:ring-offset-2 focus-visible:ring-offset-background data-[state=connecting]:from-amber-500 data-[state=connecting]:to-red-500 data-[state=playing]:border-emerald-300/50 data-[state=playing]:from-emerald-500 data-[state=playing]:via-red-500 data-[state=playing]:to-amber-400 sm:h-12 sm:min-w-52 sm:justify-start sm:px-4"
          aria-label="Escuchar radio en vivo"
          aria-pressed="false"
        >
          <span class="absolute inset-0 bg-white/0 transition group-hover:bg-white/10"></span>
          <span
            id="liveStatusDot"
            class="relative h-2.5 w-2.5 rounded-full bg-white shadow-[0_0_0_4px_rgba(255,255,255,0.18)] group-data-[state=connecting]:animate-pulse group-data-[state=playing]:bg-emerald-100"
            aria-hidden="true"
          ></span>
          <span class="relative flex min-w-0 flex-col leading-none">
            <span
              id="liveButtonText"
              class="hidden text-left text-sm font-black uppercase tracking-[0.16em] sm:block"
            >
              Escuchar en vivo
            </span>
            <span
              id="liveButtonMobileText"
              class="text-xs font-black uppercase tracking-[0.14em] sm:hidden"
            >
              En vivo
            </span>
            <span
              id="liveButtonSubtext"
              class="mt-1 hidden text-left text-[0.66rem] font-semibold uppercase tracking-[0.18em] text-white/75 sm:block"
            >
              94.5 FM · Radio online
            </span>
          </span>
          <span class="relative ml-auto flex h-8 w-8 items-center justify-center rounded-full bg-white/18 ring-1 ring-white/25 sm:h-9 sm:w-9">
            <svg
              id="livePlayIcon"
              class="h-4 w-4 translate-x-0.5"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M8 5.14v13.72a1 1 0 0 0 1.5.86l11.76-6.86a1 1 0 0 0 0-1.72L9.5 4.28A1 1 0 0 0 8 5.14Z"></path>
            </svg>
            <svg
              id="livePauseIcon"
              class="hidden h-4 w-4"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M8 5a2 2 0 0 1 2 2v10a2 2 0 1 1-4 0V7a2 2 0 0 1 2-2Zm8 0a2 2 0 0 1 2 2v10a2 2 0 1 1-4 0V7a2 2 0 0 1 2-2Z"></path>
            </svg>
          </span>
        </button>
        <p
          id="liveFeedback"
          class="absolute right-0 top-[calc(100%+0.5rem)] hidden w-64 rounded-xl border border-white/10 bg-background/95 p-3 text-xs font-semibold text-muted-foreground shadow-2xl shadow-black/40 backdrop-blur"
          role="status"
        >
          Conectando con la señal...
        </p>
        <audio
          id="radioPlayer"
          preload="none"
          playsinline
          title="Audio de Gente Comunicaciones en Vivo"></audio>
      </div>

      <Button
        id="menuButton"
        variant="ghost"
        size="icon"
        class="lg:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <svg
          id="hamburgerIcon"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="closeIcon"
          class="hidden h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </Button>
    </div>
  </div>

  <nav id="mobileMenu" class="hidden border-t border-white/10 bg-background/95 lg:hidden">
    <div class="container-page py-4">
      <ul class="grid gap-2">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="block rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-center text-sm font-semibold text-white transition hover:bg-white/10"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</header>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const liveButton = document.getElementById("liveButton");
    const audioPlayer = document.getElementById("radioPlayer");
    const liveButtonText = document.getElementById("liveButtonText");
    const liveButtonMobileText = document.getElementById("liveButtonMobileText");
    const liveButtonSubtext = document.getElementById("liveButtonSubtext");
    const liveFeedback = document.getElementById("liveFeedback");
    const livePlayIcon = document.getElementById("livePlayIcon");
    const livePauseIcon = document.getElementById("livePauseIcon");
    const menuButton = document.getElementById("menuButton");
    const mobileMenu = document.getElementById("mobileMenu");

    const hamburgerIcon = document.getElementById("hamburgerIcon");
    const closeIcon = document.getElementById("closeIcon");

    if (
      !liveButton ||
      !audioPlayer ||
      !liveButtonText ||
      !liveButtonMobileText ||
      !liveButtonSubtext ||
      !liveFeedback ||
      !livePlayIcon ||
      !livePauseIcon ||
      !menuButton ||
      !mobileMenu ||
      !hamburgerIcon ||
      !closeIcon
    ) {
      return;
    }

    if (!(audioPlayer instanceof HTMLAudioElement)) {
      return;
    }

    let liveState = "idle";
    let playAttempt = 0;

    const liveCopy = {
      idle: {
        desktop: "Escuchar en vivo",
        mobile: "En vivo",
        subtext: "94.5 FM · Radio online",
        feedback: "Listo para conectar con la señal.",
      },
      connecting: {
        desktop: "Conectando",
        mobile: "Conectando",
        subtext: "Abriendo señal segura",
        feedback: "Conectando con la señal en vivo...",
      },
      playing: {
        desktop: "Escuchando",
        mobile: "Al aire",
        subtext: "Señal en vivo activa",
        feedback: "Estás escuchando Gente Comunicaciones.",
      },
      error: {
        desktop: "Reintentar",
        mobile: "Reintentar",
        subtext: "No se pudo abrir la señal",
        feedback: "No pudimos conectar la radio. Intenta nuevamente en unos segundos.",
      },
    };

    function setLiveState(state, customMessage) {
      const copy = liveCopy[state] || liveCopy.idle;

      liveState = state;
      liveButton.dataset.state = state;
      liveButton.setAttribute("aria-pressed", String(state === "playing"));
      liveButtonText.textContent = copy.desktop;
      liveButtonMobileText.textContent = copy.mobile;
      liveButtonSubtext.textContent = copy.subtext;
      liveFeedback.textContent = customMessage || copy.feedback;
      liveFeedback.classList.toggle("hidden", state !== "connecting" && state !== "error");
      livePlayIcon.classList.toggle("hidden", state === "playing" || state === "connecting");
      livePauseIcon.classList.toggle("hidden", state !== "playing");
    }

    function ensureAudioSource() {
      if (!audioPlayer.src) {
        audioPlayer.src = liveButton.dataset.streamUrl || "/api/radio";
        audioPlayer.load();
      }
    }

    liveButton.addEventListener("click", async function () {
      if (liveState === "connecting") {
        return;
      }

      if (!audioPlayer.paused) {
        playAttempt += 1;
        audioPlayer.pause();
        setLiveState("idle", "Reproducción pausada.");
        return;
      }

      const currentAttempt = playAttempt + 1;
      playAttempt = currentAttempt;

      try {
        setLiveState("connecting");
        ensureAudioSource();
        await audioPlayer.play();
        if (currentAttempt !== playAttempt) {
          return;
        }
        setLiveState("playing");
      } catch (error) {
        if (
          currentAttempt !== playAttempt ||
          (error instanceof Error && error.name === "AbortError")
        ) {
          return;
        }

        console.error("Error al reproducir el audio:", error);
        audioPlayer.removeAttribute("src");
        audioPlayer.load();
        setLiveState("error");
      }
    });

    audioPlayer.addEventListener("playing", () => setLiveState("playing"));
    audioPlayer.addEventListener("waiting", () => setLiveState("connecting"));
    audioPlayer.addEventListener("stalled", () => {
      if (!audioPlayer.paused) {
        setLiveState("connecting", "La señal está tardando en responder...");
      }
    });
    audioPlayer.addEventListener("pause", () => {
      if (!audioPlayer.ended) {
        setLiveState("idle", "Reproducción pausada.");
      }
    });
    audioPlayer.addEventListener("ended", () => setLiveState("idle"));
    audioPlayer.addEventListener("error", () => {
      if (liveState === "idle") {
        return;
      }

      audioPlayer.removeAttribute("src");
      audioPlayer.load();
      setLiveState("error");
    });

    function closeMobileMenu() {
      mobileMenu.classList.add("hidden");
      hamburgerIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
      menuButton.setAttribute("aria-expanded", "false");
    }

    menuButton.addEventListener("click", function () {
      mobileMenu.classList.toggle("hidden");
      hamburgerIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
      menuButton.setAttribute(
        "aria-expanded",
        String(!mobileMenu.classList.contains("hidden"))
      );
    });

    mobileMenu.addEventListener("click", function (event) {
      if (event.target instanceof Element && event.target.closest("a")) {
        closeMobileMenu();
      }
    });

    document.addEventListener("astro:before-swap", closeMobileMenu);
  });
</script>
